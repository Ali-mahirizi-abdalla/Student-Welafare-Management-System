# Environment Variables Template for PythonAnywhere Deployment
# Copy this file to .env and fill in your actual values

# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=campus-care.co.ke,www.campus-care.co.ke,localhost,127.0.0.1

# Database Configuration
# FOR SQLite: Set USE_SQLITE=True and ignore DB settings below
USE_SQLITE=True

# FOR MySQL: Set USE_SQLITE=False and fill in details below
DB_NAME=swms_db
DB_USER=root
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=3306

# Email Configuration
ADMIN_EMAIL=your-admin-email@example.com
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# M-Pesa Configuration (Optional)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://campus-care.co.ke/payment/callback/

# Telegram Emergency Broadcast
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-channel-username-or-id
